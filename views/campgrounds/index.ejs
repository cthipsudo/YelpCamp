<% layout('layouts/clusterMap')%>

<h1 class="my-5">All Campgrounds </h1>

<main class="campgroundListContainer">
  <% for ( let campground of campgrounds ) { %>
  <div class="card mb-3">
    <div class="row g-0">
      <div class="col-md-5 col-lg-4">
        <img class="img-fluid rounded-start" src="<%= campground.images.length ? campground.images[0].url : 'https://res.cloudinary.com/dorflj0ap/image/upload/v1772386761/YelpCamp/c7pys7lslszlwhd8elz9.jpg' %>" class="img-fluid" alt="">
      </div>
      <div class="col-md-7 col-lg-8">
        <div class="card-body">
          <h5 class="card-title"><%= campground.title %></h5>
          <p class="card-text"><%= campground.description.substring(0,80)%>...</p>
          <p class="card-text">
            <small class="text-secondary">
              <%= campground.location %>
            </small>
          </p>
          <a href="/campgrounds/<%= campground._id %>" class="btn btn-primary">View <%= campground.title %></a>
        </div>
      </div>
    </div>
  </div>
  <% } %>

